{
  "name": "newmomcircle-e2e",
  "version": "2.0.0",
  "description": "Enterprise Appium 2.x E2E Automation Framework for NewMomCircle Android App",
  "main": "index.js",
  "scripts": {
    "test":             "mocha 'tests/**/*.js' --ignore 'tests/base/**'",
    "test:auth":        "mocha 'tests/auth/*.js'",
    "test:feed":        "mocha 'tests/feed/*.js'",
    "test:explore":     "mocha 'tests/explore/*.js'",
    "test:forms":       "mocha 'tests/forms/*.js'",
    "test:navigation":  "mocha 'tests/navigation/*.js'",
    "test:tracker":     "mocha 'tests/tracker/*.js'",
    "test:messages":    "mocha 'tests/messages/*.js'",
    "test:profile":     "mocha 'tests/profile/*.js'",
    "test:performance": "mocha 'tests/performance/*.js'",
    "test:safety":      "mocha 'tests/safety/*.js'",
    "test:ci":          "mocha 'tests/**/*.js' --ignore 'tests/base/**'",
    "report":           "marge mochawesome-report/mochawesome.json -f index -o reports/html"
  },
  "dependencies": {
    "dotenv":     "^16.3.1",
    "exceljs":    "^4.3.0",
    "winston":    "^3.10.0",
    "webdriverio":"^8.16.11"
  },
  "devDependencies": {
    "appium":                        "^2.0.1",
    "appium-uiautomator2-driver":    "^3.10.0",
    "chai":                          "^4.3.8",
    "mocha":                         "^10.2.0",
    "mochawesome":                   "^7.1.3",
    "mochawesome-merge":             "^4.3.0",
    "mochawesome-report-generator":  "^6.2.0"
  }
}
