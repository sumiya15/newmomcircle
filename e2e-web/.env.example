# ─── Web E2E .env ─────────────────────────────────────────────────────────────
# Copy this to .env and fill in real values (never commit .env to git)

# Base URL of the deployed web app (or localhost for local runs)
WEB_BASE_URL=http://localhost:3000

# Test account credentials
TEST_USER_EMAIL=testuser@newmomcircle.test
TEST_USER_PASSWORD=TestPass123!
TEST_USER_NAME=Test Mom

# Browser options (true = headless, false = headed)
# In CI this is automatically set to true by the GitHub Actions workflow
HEADLESS=false
